# Downloaded providers and modules — regenerated by terraform init
.terraform/

# Local variable overrides (committed env files are fine; exclude personal overrides)
*.tfvars
*.tfvars.json
!prod.tfvars

# Crash logs
crash.log
crash.*.log

# Sensitive state files (managed by S3 backend)
terraform.tfstate
terraform.tfstate.backup
.terraform.tfstate.lock.info

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
